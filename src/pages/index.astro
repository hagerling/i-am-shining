---
import Layout from '../layouts/Layout.astro';
import { ImageEditor } from '../components/ImageEditor';
import { SocialFeed } from '../components/SocialFeed';
import { DiscoBall } from '../components/DiscoBall';
import testimonials from '../data/testimonials.json';
---

<Layout>
  <DiscoBall client:only="react" />

  {/* Background glitter — fixed behind everything, drifts slowly. */}
  <div class="page-glitter" aria-hidden="true"></div>

  <main id="main-content" tabindex="-1">
    {/* Cloud puffs — soft warm/pink glows in the upper corners of the page. */}
    <div class="cloud-puff cloud-puff--tl" aria-hidden="true"></div>
    <div class="cloud-puff cloud-puff--tr" aria-hidden="true"></div>

    {/* Banner lives behind everything as an absolute layer — it never
        pushes the hero text or profile circle, so they stay in exactly
        the same position whether a photo is loaded or not. */}
    <div id="banner-slot"></div>

    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-inner">
        <h1 id="hero-title">
          <span class="hero-i">I am</span>
          <em class="glitter-text">#Shining</em>
        </h1>
        <span class="ribbon hero-ribbon" aria-hidden="true">
          shine bright in your golden season
        </span>
      </div>
    </section>

    <section
      id="step-upload"
      class="editor-section reveal"
      aria-label="Profile photo editor"
    >
      {/* Sunburst rays radiate from behind the profile circle while the
          dropzone is showing. Hidden once a banner takes over. */}
      <div class="sunburst-rays" aria-hidden="true"></div>
      {/* The HowTo schema deep-links to #step-upload, #step-adjust,
          #step-download — all live inside the editor section. The two
          inner anchor markers below have no visible content; they exist
          purely for the structured-data URLs to resolve. */}
      <span id="step-adjust"   class="sr-only">Adjust the look</span>
      <span id="step-download" class="sr-only">Download</span>
      <ImageEditor client:load />
    </section>

    <div class="divider reveal"></div>

    <div class="reveal">
      <SocialFeed testimonials={testimonials} client:load />
    </div>

    <div class="divider reveal"></div>

    <!-- FAQ -->
    <section class="faq-section reveal" aria-labelledby="faq-heading">
      <div class="faq-label">FAQ</div>
      <h2 id="faq-heading" class="faq-heading">
        <span class="heading-sparkle">Frequently Asked Questions</span>
      </h2>
      <p class="faq-subhead">Here are some questions I get asked.</p>

      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-question">What is #Shining?</summary>
          <p class="faq-answer">
            #Shining is a movement for people who want to show up with energy, optimism, and a golden glow. Upgrade your profile picture with the radiant Shining frame and signal to the world that you&apos;re in your brightest season.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How did #Shining get started?</summary>
          <p class="faq-answer">
            Over a round of cold beers on a warm evening, a few friends got talking about how flat the feed had started to feel — everyone posting the same corporate headshots, the same polished smiles, none of the spark. The conversation went somewhere brighter: what if a profile picture could remind you to show up with a little more optimism? By the second pint there were sketches on a napkin. By the next morning there was code. Turns out an optimistic mindset is contagious — it spreads through every bling, every shine, every tiny golden pixel. That&apos;s how this began, and it&apos;s why we still keep it simple, playful, and free.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How do I add my Shining picture to LinkedIn?</summary>
          <p class="faq-answer">
            After downloading your PNG, go to your LinkedIn profile and click on your current profile photo. Select <strong>Change photo</strong>, upload the downloaded file, and use LinkedIn&apos;s built-in crop tool to position it. Your circular Shining frame will fit perfectly since the download is already cropped to a circle. Hit <strong>Apply</strong> and your golden profile is live.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Will the frame work on other platforms?</summary>
          <p class="faq-answer">
            Yes — the downloaded PNG is a square image with a circular transparent background, which works on LinkedIn, X (Twitter), Instagram, Slack, GitHub, and most other platforms that support PNG uploads with transparency.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What size is the downloaded image?</summary>
          <p class="faq-answer">
            The image downloads at 600×600 px, which is the recommended size for LinkedIn profile photos and meets the minimum requirements for most social platforms.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Is my photo uploaded anywhere?</summary>
          <p class="faq-answer">
            No. Everything happens entirely in your browser — your photo is never sent to any server. The canvas processing, iridescent effect, and frame overlay are all done locally on your device.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How do I get the best result?</summary>
          <p class="faq-answer">
            Use a photo where your face is centred and well-lit. After uploading, drag to reposition and scroll to zoom until your face sits comfortably inside the circular frame. Adjust the Shine Intensity slider to taste — around 40–60% tends to look natural while still catching the light.
          </p>
        </details>
      </div>
    </section>

    <footer class="site-footer reveal" aria-labelledby="footer-tagline">
      <div class="footer-inner">
        <p id="footer-tagline" class="footer-tagline">
          Keep <em>shining</em>, beautiful soul.
          <span class="footer-heart" aria-hidden="true">♡</span>
        </p>
        <p class="footer-meta">
          Built privacy-first. Your photo never leaves the browser.
        </p>
        <nav class="footer-nav" aria-label="External links">
          <a href="https://github.com/hagerling/i-am-shining" rel="noopener noreferrer" target="_blank">Source</a>
          <span aria-hidden class="footer-sep">·</span>
          <a href="#faq-heading">FAQ</a>
          <span aria-hidden class="footer-sep">·</span>
          <a href="mailto:carl.hagerling@gmail.com">Contact</a>
        </nav>
        <p class="footer-credit">
          Made by <a href="https://github.com/hagerling" rel="noopener noreferrer" target="_blank">Carl Hagerling</a>
        </p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* ── Scroll reveal ───────────────────────── */
  .reveal {
    opacity: 0;
    transition: opacity 0.75s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.is-visible {
    opacity: 1;
  }

  /* ── Banner layer ───────────────────────────
     Absolute at the top of <main>, behind everything. Never affects flow,
     so the hero text and profile circle never shift when a photo loads. */
  #banner-slot {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 0;
  }

  /* Banner height is set directly in HeaderGenerator.tsx so it correctly
   * applies (Astro scoped styles don't reach React-portaled elements). */

  /* When a photo is loaded, the hero text turns white for contrast on banner */
  .has-photo .hero {
    background: transparent;
  }

  .has-photo .hero h1 {
    color: #fff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.55);
    transition: color 0.4s ease, text-shadow 0.4s ease;
  }

  .has-photo .hero h1 em {
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
    -webkit-text-fill-color: #fff;
    filter: drop-shadow(0 0 12px rgba(255,215,0,0.5));
  }

  /* ── Page structure ───────────────────────── */
  main {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero {
    position: relative;
    z-index: 10;
    width: 100%;
    /* Fixed height — ensures the hero text AND the profile circle are at
     * the exact same positions whether a photo is loaded or not. Banner
     * height in HeaderGenerator is `12rem + min(45vw, 200px)` so its bottom
     * lands on the circle centre. */
    height: 12rem;
    padding: 1rem 1rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: radial-gradient(ellipse 80% 60% at 50% 50%, hsla(40, 80%, 30%, 0.25) 0%, transparent 70%);
    transition: background 0.4s ease;
    /* Hero is just text; let clicks pass through so the banner's corner
     * buttons (refresh / download) aren't blocked. */
    pointer-events: none;
  }

  .hero-inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
  }

  /* Italic display tagline under the hero — mockup-inspired, fades when
   * a photo loads so it doesn't compete with the banner. */
  .hero-tagline {
    margin: 0;
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: clamp(0.85rem, 1.4vw, 1.05rem);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    transition: opacity 0.4s ease;
  }
  .hero-tagline-mark {
    font-style: normal;
    background: linear-gradient(135deg, var(--color-gold-dim), var(--color-gold-light));
    -webkit-background-clip: text;
            background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 0.85em;
  }
  .has-photo .hero-tagline {
    opacity: 0;
    pointer-events: none;
  }

  h1 {
    font-family: 'DM Serif Display', serif;
    /* Bumped: more theatrical, mockup-scale display type. */
    font-size: clamp(3.25rem, 8.5vw, 6.5rem);
    line-height: 1.0;
    color: var(--color-text);
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 0.32em;
    letter-spacing: -0.012em;
  }
  .hero-i {
    font-style: normal;
    color: var(--color-text);
    /* Subtle inner shadow for depth */
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.30);
  }
  .has-photo .hero-i {
    color: #fff;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.55);
  }
  /* Italic hero accent now uses .glitter-text utility — overrides the
   * old gold gradient. Add a subtle bling pulse on top of glitter. */
  h1 em.glitter-text {
    font-style: italic;
  }
  /* The pre-existing bling animation reads background-position; with the
   * shimmer keyframe owning that property, disable bling on glitter-text
   * to avoid jitter. */
  h1 em.glitter-text.bling {
    animation: glitter-shimmer 9s ease-in-out infinite, bling-pulse 1.4s ease-out;
  }
  @keyframes bling-pulse {
    0%, 100% { filter:
      drop-shadow(0 1px 0 rgba(0, 0, 0, 0.30))
      drop-shadow(0 0 18px rgba(255, 215, 0, 0.35))
      drop-shadow(0 0 36px rgba(255, 200, 80, 0.20));
    }
    40% { filter:
      drop-shadow(0 1px 0 rgba(0, 0, 0, 0.30))
      drop-shadow(0 0 30px rgba(255, 235, 130, 0.85))
      drop-shadow(0 0 60px rgba(255, 215, 0, 0.55));
    }
  }
  .hero-ribbon {
    margin-top: 0.4rem;
  }

  h1 em {
    font-style: italic;
    /* Default inline display so ascenders/descenders aren't clipped — the
     * box on an inline-block em is sized by font-size + line-height and
     * scale transforms will push glyphs outside it. */
    background: linear-gradient(
      100deg,
      var(--color-gold-dim) 0%,
      var(--color-gold-light) 30%,
      #fffde5 50%,
      var(--color-gold-light) 70%,
      var(--color-amber) 100%
    );
    background-size: 260% 100%;
    background-position: 50% 50%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: filter 0.35s;
  }

  /* Random bling: gradient sweep across the word + a pulsing golden glow.
     No transform scale (would push glyphs outside the inline box → clipping)
     and no pseudo-element flare (inline elements don't render ::after in a
     positionable way without box sizing hacks that also cause clipping). */
  h1 em.bling {
    animation: shining-bling 1.4s cubic-bezier(0.22, 0.8, 0.25, 1) both;
  }

  @keyframes shining-bling {
    0% {
      background-position: -120% 50%;
      filter: drop-shadow(0 0 0 rgba(255, 215, 0, 0));
    }
    35% {
      background-position: 40% 50%;
      filter: drop-shadow(0 0 18px rgba(255, 215, 0, 0.75))
              drop-shadow(0 0 38px rgba(255, 250, 200, 0.5));
    }
    65% {
      filter: drop-shadow(0 0 12px rgba(255, 215, 0, 0.4))
              drop-shadow(0 0 26px rgba(255, 250, 200, 0.25));
    }
    100% {
      background-position: 220% 50%;
      filter: drop-shadow(0 0 0 rgba(255, 215, 0, 0));
    }
  }

  .hero-sub {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
    text-align: center;
    padding: 1.5rem 1rem 0;
    width: 100%;
  }


  .editor-section {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 700px;
    /* No top padding — the profile circle must start at exactly
     * max(25vw, 200px) from page top (i.e. immediately after .hero). */
    padding: 0 1rem 4rem;
  }


  .divider {
    width: 100%;
    max-width: 700px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-gold-dim), transparent);
    margin: 0 auto;
  }

  .site-footer {
    width: 100%;
    padding: 4rem 1.5rem 3rem;
    color: var(--color-text-muted);
    text-align: center;
    border-top: 1px solid rgba(184, 134, 11, 0.18);
    margin-top: 2rem;
    background:
      radial-gradient(ellipse 60% 100% at 50% 0%, hsla(40, 80%, 30%, 0.10) 0%, transparent 70%);
  }

  .footer-inner {
    max-width: 540px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }

  .footer-tagline {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-style: normal;
    margin: 0;
    color: var(--color-text);
    background: linear-gradient(135deg, var(--color-gold-dim), var(--color-gold-light), var(--color-amber));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.005em;
  }
  .footer-tagline em {
    font-style: italic;
  }
  .footer-heart {
    -webkit-text-fill-color: var(--color-magenta);
    color: var(--color-magenta);
    margin-left: 0.25rem;
    font-style: normal;
    text-shadow: 0 0 18px rgba(255, 95, 141, 0.45);
  }

  .footer-mark {
    font-style: normal;
    margin-right: 0.05em;
  }

  .footer-meta {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
    justify-content: center;
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }

  .footer-nav a {
    color: var(--color-gold-light);
    text-decoration: none;
    padding: 0.2rem 0.4rem;
    border-radius: 0.35rem;
    transition: background 0.2s;
  }

  .footer-nav a:hover {
    background: rgba(218, 165, 32, 0.12);
  }

  .footer-sep {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .footer-credit {
    margin: 0.4rem 0 0;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  .footer-credit a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(218, 165, 32, 0.5);
  }

  /* ── FAQ ─────────────────────────────────── */
  .faq-section {
    width: 100%;
    max-width: 700px;
    padding: 0 1rem 5rem;
  }

  .faq-label {
    display: inline-block;
    background: linear-gradient(90deg, var(--color-gold-dim), var(--color-gold-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .faq-heading {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    color: var(--color-text);
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }
  .faq-section { text-align: center; }
  .faq-section .faq-list { text-align: left; margin-top: 2rem; }
  .faq-subhead {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    margin: 0 0 1.75rem;
    letter-spacing: 0.01em;
  }

  /* FAQ list inside a luminous frosted box — mockup motif. */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0.5rem 1.5rem;
    margin: 0 auto;
    max-width: 620px;
    border-radius: 1.5rem;
    background:
      linear-gradient(168deg,
        rgba(48, 30, 10, 0.55) 0%,
        rgba(28, 18, 6, 0.40) 60%,
        rgba(20, 12, 3, 0.35) 100%);
    border: 1px solid transparent;
    backdrop-filter: blur(28px) saturate(150%);
    -webkit-backdrop-filter: blur(28px) saturate(150%);
    box-shadow:
      inset 0 1px 0 rgba(255, 245, 210, 0.10),
      0 1px 2px rgba(0, 0, 0, 0.30),
      0 14px 40px rgba(0, 0, 0, 0.34),
      0 0 60px rgba(218, 165, 32, 0.10);
    position: relative;
  }
  /* Gradient ring around the FAQ box, same trick as the testimonial cards. */
  .faq-list::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(160deg,
      rgba(255, 232, 140, 0.55) 0%,
      rgba(218, 165, 32, 0.30) 25%,
      rgba(184, 134, 11, 0.18) 55%,
      rgba(184, 134, 11, 0.10) 80%,
      rgba(255, 215, 0, 0.18) 100%);
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
  }
  [data-theme="light"] .faq-list {
    background:
      linear-gradient(168deg,
        rgba(255, 250, 235, 0.78) 0%,
        rgba(252, 244, 225, 0.62) 100%);
  }

  .faq-item {
    border-bottom: 1px solid rgba(184,134,11,0.16);
  }
  .faq-item:last-child { border-bottom: none; }

  .faq-question {
    list-style: none;
    cursor: pointer;
    padding: 1.25rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    user-select: none;
    transition: color 0.2s;
  }

  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::marker { display: none; }

  .faq-question::after {
    content: '';
    flex-shrink: 0;
    width: 0.6rem;
    height: 0.6rem;
    border-right: 2px solid var(--color-gold-light);
    border-bottom: 2px solid var(--color-gold-light);
    transform: rotate(45deg);
    transition: transform 0.25s cubic-bezier(0.22,1,0.36,1),
                border-color 0.25s ease;
    margin-bottom: 0.2rem;
    filter: drop-shadow(0 0 6px rgba(255, 215, 0, 0.35));
  }
  .faq-item[open] .faq-question::after {
    transform: rotate(-135deg);
    margin-bottom: -0.2rem;
  }

  .faq-item[open] .faq-question {
    color: var(--color-gold-light);
  }

  /* JS-driven open/close animation — see <script> below. We just need the
   * answer to overflow-clip during the height transition. */
  .faq-answer {
    margin: 0;
    padding: 0 0 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    overflow: hidden;
  }

  .faq-answer strong {
    color: var(--color-text);
    font-weight: 600;
  }
</style>

<script>
  // Random bling on the hero "Shining" word — every 4–11 seconds the word
  // gets a shine-sweep + outline glow + travelling lens flare. Pauses when
  // the user has prefers-reduced-motion on, and when the hero isn't visible.
  const shiningEm = document.querySelector<HTMLElement>('h1 em');
  if (shiningEm) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let visible = true;
    let blingTimer: number | undefined;
    const trigger = () => {
      if (!visible) {
        blingTimer = window.setTimeout(trigger, 2000);
        return;
      }
      shiningEm.classList.add('bling');
      window.setTimeout(() => shiningEm.classList.remove('bling'), 1500);
      blingTimer = window.setTimeout(trigger, 4000 + Math.random() * 7000);
    };
    if (!reduced) {
      // Track hero visibility so we don't burn cycles off-screen
      const hero = shiningEm.closest('section');
      if (hero) {
        new IntersectionObserver((entries) => {
          visible = entries[0]?.isIntersecting ?? true;
        }, { threshold: 0.2 }).observe(hero);
      }
      blingTimer = window.setTimeout(trigger, 2500 + Math.random() * 2500);
    }
  }

  // FAQ accordion — animate expand/collapse with height + fade + slight rise.
  // We intercept summary clicks because the native <details> toggle is
  // instant; this lets us cleanly drive the transition.
  const faqItems = document.querySelectorAll<HTMLDetailsElement>('.faq-list .faq-item');
  const OPEN_MS = 420;
  const CLOSE_MS = 360;
  const EASE = 'cubic-bezier(0.22, 1, 0.36, 1)';

  const animateOpen = (item: HTMLDetailsElement) => {
    const answer = item.querySelector<HTMLElement>('.faq-answer');
    if (!answer) return;
    item.open = true;
    // measure target height
    answer.style.transition = 'none';
    answer.style.maxHeight = 'none';
    answer.style.opacity = '1';
    answer.style.transform = 'none';
    answer.style.paddingBottom = '1.5rem';
    const target = answer.scrollHeight;
    // collapse to start state
    answer.style.maxHeight = '0px';
    answer.style.opacity = '0';
    answer.style.transform = 'translateY(-6px)';
    answer.style.paddingBottom = '0';
    // force reflow so the next style change is animated
    void answer.offsetHeight;
    answer.style.transition =
      `max-height ${OPEN_MS}ms ${EASE}, ` +
      `opacity ${OPEN_MS - 100}ms ease ${80}ms, ` +
      `transform ${OPEN_MS}ms ${EASE}, ` +
      `padding-bottom ${OPEN_MS}ms ${EASE}`;
    answer.style.maxHeight = target + 'px';
    answer.style.opacity = '1';
    answer.style.transform = 'translateY(0)';
    answer.style.paddingBottom = '1.5rem';
    window.setTimeout(() => {
      answer.style.transition = '';
      answer.style.maxHeight = '';
      answer.style.opacity = '';
      answer.style.transform = '';
      answer.style.paddingBottom = '';
    }, OPEN_MS + 30);
  };

  const animateClose = (item: HTMLDetailsElement) => {
    const answer = item.querySelector<HTMLElement>('.faq-answer');
    if (!answer) {
      item.open = false;
      return;
    }
    const start = answer.scrollHeight;
    answer.style.transition = 'none';
    answer.style.maxHeight = start + 'px';
    answer.style.opacity = '1';
    answer.style.transform = 'translateY(0)';
    answer.style.paddingBottom = '1.5rem';
    void answer.offsetHeight;
    answer.style.transition =
      `max-height ${CLOSE_MS}ms ${EASE}, ` +
      `opacity ${CLOSE_MS - 80}ms ease, ` +
      `transform ${CLOSE_MS}ms ${EASE}, ` +
      `padding-bottom ${CLOSE_MS}ms ${EASE}`;
    answer.style.maxHeight = '0px';
    answer.style.opacity = '0';
    answer.style.transform = 'translateY(-6px)';
    answer.style.paddingBottom = '0';
    window.setTimeout(() => {
      item.open = false;
      answer.style.transition = '';
      answer.style.maxHeight = '';
      answer.style.opacity = '';
      answer.style.transform = '';
      answer.style.paddingBottom = '';
    }, CLOSE_MS + 30);
  };

  faqItems.forEach((item) => {
    const summary = item.querySelector('summary');
    if (!summary) return;
    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (item.open) {
        animateClose(item);
      } else {
        // Only one item open at a time — close others first.
        faqItems.forEach((other) => {
          if (other !== item && other.open) animateClose(other);
        });
        animateOpen(item);
      }
    });
  });

  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        observer.unobserve(e.target); // fire once
      }
    }),
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
