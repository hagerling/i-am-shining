{
  "name": "i-am-shining",
  "type": "module",
  "version": "1.0.0",
  "description": "Upload a photo, apply the golden #Shining frame, download your radiant profile picture.",
  "homepage": "https://i-am-shining.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/hagerling/i-am-shining.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-posts": "node scripts/fetch-posts.mjs",
    "fetch-linkedin": "node scripts/fetch-linkedin.mjs",
    "deploy": "lftp -e \"mirror -R --delete --exclude .DS_Store --exclude staging/ dist/ /i-am-shining.com/public_html/; quit\" -u hagerling.se,hagerling80 ftpcluster.loopia.se",
    "build:staging": "STAGING=1 astro build",
    "deploy:staging": "lftp -e \"mirror -R --delete --exclude .DS_Store dist/ /i-am-shining.com/public_html/staging/; quit\" -u hagerling.se,hagerling80 ftpcluster.loopia.se"
  },
  "vitest": {
    "environment": "jsdom"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@use-gesture/react": "^10.3.1",
    "astro": "^6.1.9",
    "framer-motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "fast-xml-parser": "^5.7.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
